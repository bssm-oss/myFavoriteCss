{
  "name": "morph-ui",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @morph-ui/web dev",
    "dev:extension": "pnpm --filter @morph-ui/extension dev",
    "local:setup": "bash ./scripts/morph-local.sh setup",
    "local:dev": "bash ./scripts/morph-local.sh dev",
    "local:verify": "bash ./scripts/morph-local.sh verify",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @morph-ui/extension test:e2e",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "typescript": "^5.9.2"
  }
}
