{
  "name": "morph-ui",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "dev:server": "pnpm --filter @morph-ui/server dev",
    "dev:web": "pnpm --filter @morph-ui/web dev",
    "dev:extension": "pnpm --filter @morph-ui/extension dev",
    "db:generate": "pnpm --filter @morph-ui/server db:generate",
    "db:migrate": "pnpm --filter @morph-ui/server db:migrate",
    "db:seed": "pnpm --filter @morph-ui/server db:seed",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:integration": "pnpm --filter @morph-ui/server test:integration",
    "test:e2e": "pnpm --filter @morph-ui/extension test:e2e",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "typescript": "^5.9.2"
  }
}
