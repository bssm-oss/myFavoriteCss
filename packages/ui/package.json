{
  "name": "@morph-ui/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "tsup src/index.tsx --format esm --dts",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --project tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "dependencies": {
    "@morph-ui/shared": "workspace:*",
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "vitest": "^3.2.4"
  }
}
